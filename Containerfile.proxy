FROM alpine:3.22

RUN apk add --no-cache ca-certificates squid \
  && mkdir -p /var/cache/squid /var/log/squid /run/squid \
  && chown -R squid:squid /var/cache/squid /var/log/squid /run/squid

COPY proxy/squid-nonlocal.conf /etc/squid/squid.conf

USER squid
EXPOSE 3128

CMD ["squid", "-N", "-f", "/etc/squid/squid.conf", "-d", "1"]
