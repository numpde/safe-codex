# Copy to .env if you want local defaults. The launcher never reads host
# ~/.codex; use an API key or perform a fresh login inside the container volume.

# SAFE_CODEX_ENGINE=podman
# SAFE_CODEX_PROFILE=default
# SAFE_CODEX_NETWORK=proxy
# SAFE_CODEX_PROXY_MODE=nonlocal
# SAFE_CODEX_EXTERNAL_NETWORK=safe-codex-egress-nonlocal
# SAFE_CODEX_WORKSPACE=/absolute/path/to/project
# SAFE_CODEX_WORKSPACE_MODE=rw
# Use SAFE_CODEX_WORKSPACE_MODE=ro for inspection-first sessions, then pass
# --workspace-rw when a specific run should edit the workspace.
# SAFE_CODEX_GPU=none
# Examples:
# SAFE_CODEX_GPU=nvidia
# SAFE_CODEX_GPU=nvidia:0
# SAFE_CODEX_GPU=dri:/dev/dri/renderD129
# SAFE_CODEX_AMD_IGPU_RENDER=/dev/dri/by-path/pci-0000:7a:00.0-render
# SAFE_CODEX_MEMORY=2g
# SAFE_CODEX_CPUS=2
# SAFE_CODEX_PIDS_LIMIT=512

# Optional. Prefer exporting this in your shell instead of storing it in .env.
# OPENAI_API_KEY=
